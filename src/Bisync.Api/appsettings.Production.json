{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/bisync.db;Cache=Shared;Default Timeout=60"
  },
  "StockCardArchive": {
    "Directory": "/app/data/archives/stock-card",
    "RetentionYears": 2,
    "RunOnStartup": true,
    "IntervalHours": 24
  }
}
