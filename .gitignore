# Build outputs
bin/
obj/

# SQLite temp/lock files (never commit these)
*.db-shm
*.db-wal

# Ignore other databases; allow Bisync app DB and named backups under src/Bisync.Api/
*.db
!src/Bisync.Api/
!src/Bisync.Api/*.db

# Local backup copies (optional — run scripts/backup-data.ps1)
data-backups/

# Stock card archive database (generated by StockCardArchiveService)
data-archives/stock-card/*.db

# Independent COGS audit history payloads (can be large)
data-archives/cogs-audit-history/runs/
data-archives/cogs-audit-history/system/**/cogs-audit.json

# .NET
.vs/
*.user
*.suo

# Node
node_modules/
client/dist/
dist/

# Environment
.env
.env.local
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
